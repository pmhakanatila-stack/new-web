{
  "name": "peyzajder-new-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "check:syntax": "node scripts/check-syntax.mjs",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:legacy-content": "node scripts/check-legacy-content.mjs",
    "clean:legacy-links": "node scripts/clean-legacy-links.mjs",
    "migrate:legacy-news-images": "node scripts/apply-legacy-news-images.mjs seed-cms.json",
    "migrate:legacy-news-images-live": "node scripts/apply-legacy-news-images.mjs ../private_data/cms.json",
    "diag:content-image-live": "node scripts/diag-content-image.mjs ../private_data/cms.json",
    "diag:content-image-datadir": "node scripts/diag-content-image.mjs data/cms.json",
    "diag:env": "node -e \"console.log('PEYZAJDER_DATA_DIR=',process.env.PEYZAJDER_DATA_DIR,'cwd=',process.cwd())\"",
    "diag:static-shadow": "node scripts/diag-static-shadow.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test": "npm run check:syntax && npm run check:encoding && npm run check:legacy-content && npm run test:smoke"
  },
  "engines": {
    "node": ">=20"
  }
}
